{
  "name": "cotta",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cd agent && npm install && cd ../web && npm install",
    "dev": "tsx watch node/index.ts",
    "dev:web": "cd web && npm run dev",
    "build": "tsc -p tsconfig.json",
    "build:agent": "cd agent && npm run build",
    "build:web": "cd web && npm run build",
    "build:all": "npm run build && npm run build:agent && npm run build:web",
    "start": "node dist/node/index.js",
    "test:cli": "tsx node/cli-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.89",
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.0",
    "dotenv": "^16.4.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
