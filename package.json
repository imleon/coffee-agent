{
  "name": "coffee-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cd agent && npm install",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:agent": "cd agent && npm run build",
    "build:all": "npm run build && npm run build:agent",
    "start": "node dist/index.js",
    "test:cli": "tsx src/cli-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
